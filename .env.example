APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Brevo (Sendinblue) Configuration
# Obtén tu API key desde: https://app.brevo.com/settings/keys/api
BREVO_KEY=
BREVO_SMS_SENDER=JSTACK

# ============================================================================
# WhatsApp Business API (Meta) - CONFIGURACIÓN CENTRALIZADA
# ============================================================================
# Este número de WhatsApp será usado para enviar notificaciones de TODAS
# las empresas/perfiles del sistema (modelo centralizado).
#
# PASOS PARA CONFIGURAR:
#
# 1. Ve a: https://developers.facebook.com/apps/
# 2. Crea una app → Selecciona "Conectarte con clientes a través de WhatsApp"
# 3. Configura el webhook en Meta con esta URL:
#    https://tu-dominio.com/api/whatsapp/webhook
# 4. Usa el mismo valor de WHATSAPP_WEBHOOK_VERIFY_TOKEN aquí y en Meta
# 5. Crea un Usuario del Sistema en Configuración del Negocio
# 6. Genera un Token Permanente con estos permisos:
#    - business_management
#    - whatsapp_business_messaging
#    - whatsapp_business_management
#
# VALORES A CONFIGURAR:
WHATSAPP_ACCESS_TOKEN=           # Token permanente del Usuario del Sistema
WHATSAPP_PHONE_NUMBER_ID=        # ID del número (ej: 123456789012345)
WHATSAPP_BUSINESS_PHONE_NUMBER=  # Tu número con código de país (ej: 51987654321)
WHATSAPP_API_VERSION=v21.0       # Versión de la API (no cambiar)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=   # Token de verificación (inventa uno seguro)

# Cron Job Token
# Token de seguridad para proteger el endpoint de cron jobs
# Genera uno con: php artisan tinker -> Str::random(32)
CRON_TOKEN=

# Google OAuth Configuration
# Obtén estas credenciales desde: https://console.cloud.google.com/apis/credentials
# 1. Crea un proyecto en Google Cloud Console
# 2. Habilita la API de Google+
# 3. Crea credenciales OAuth 2.0 (Web Application)
# 4. Agrega authorized redirect URIs: http://localhost/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
