# Configuración de Filesystem para Producción
# Estas variables deben agregarse al .env en producción

# Ruta física donde se guardan los archivos (fuera de Laravel)
FILESYSTEM_PUBLIC_ROOT=/home/usuario/public_html/uploaded_files

# Path público en la URL (sin barra inicial ni final)
FILESYSTEM_PUBLIC_PATH=uploaded_files

# Ejemplo de URL completa resultante:
# Si APP_URL=https://midominio.com
# Y FILESYSTEM_PUBLIC_PATH=uploaded_files
# Las URLs serán: https://midominio.com/uploaded_files/stories/4/story_xxx.webp
